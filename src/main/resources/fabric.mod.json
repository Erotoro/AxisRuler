{
  "schemaVersion": 1,
  "id": "axisruler",
  "version": "${version}",
  "name": "AxisRuler",
  "description": "Client-side visual block measurement tool",
  "authors": [
    "Erotoro"
  ],
  "contact": {
    "sources": "https://github.com/Erotoro/AxisRuler"
  },
  "icon": "assets/axisruler/icon.png",
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.axisruler.AxisRulerClient"
    ],
    "modmenu": [
      "com.axisruler.integration.modmenu.AxisRulerModMenuIntegration"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "fabric-api": ">=${fabric_version}"
  },
  "suggests": {
    "modmenu": ">=${modmenu_version}"
  }
}
