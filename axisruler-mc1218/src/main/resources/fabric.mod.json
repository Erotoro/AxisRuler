  "authors": [
    "Erotoro"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/axisruler",
    "sources": "https://github.com/Erotoro/AxisRuler",
    "issues": "https://github.com/Erotoro/AxisRuler/issues"
  },
  "icon": "assets/axisruler/icon.png",
